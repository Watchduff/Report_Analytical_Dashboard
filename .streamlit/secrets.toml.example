# Copy this file to .streamlit/secrets.toml and fill in your real Neon
# connection string. secrets.toml is gitignored — never commit it.
#
# Find your connection string in the Neon console: Project -> Connect.
# Keep "?sslmode=require" at the end; Neon requires SSL.

[connections.neon]
type = "sql"
url = "postgresql://<user>:<password>@<host>/<dbname>?sslmode=require"
